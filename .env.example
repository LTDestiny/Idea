# Example environment variables for the Idea app
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Client-exposed (visible to browser) — must be prefixed with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional / Server-only (do not expose to client)
# SUPABASE_SERVICE_ROLE_KEY=

# Other platform-specific vars (example)
# NEXT_PUBLIC_APP_URL=